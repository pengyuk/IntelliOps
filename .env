# IntelliOps LLM Configuration
# Copy this file to .env and fill in your values.

# LLM provider: openai | anthropic | ollama | none (default stub)
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-e59f979a2f544007819de4278792d350
OPENAI_MODEL=qwen3.7-plus
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # optional, for proxies

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- General ---
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SEC=60.0

# --- Startup ---
SKIP_DB_INIT=1       # 跳过数据库初始化
SKIP_DATA_LOAD=1     # 跳过 Excel/Word 数据文件加载（加速启动，数据可通过 POST /data/reload 按需加载）
